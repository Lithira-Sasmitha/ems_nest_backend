DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=ems_db

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=yourRefreshSecret
JWT_REFRESH_EXPIRES_IN=7d

# optional — super admin defaults (used by ensureSuperAdmin)
SUPER_ADMIN_EMAIL=admin@system.com
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=System Super Admin
SUPER_ADMIN_PHONE=0000000000
SUPER_ADMIN_NIC=000000000V
